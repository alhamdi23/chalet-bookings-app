// Firestore security rules — chalet booking app (login required)
//
// Paste these into  Firebase console > Build > Firestore Database > Rules,
// then click Publish.
//
// These rules require the user to be signed in (Firebase Authentication) before
// they can read or write any data. Create accounts under
// Build > Authentication > Users.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /bookings/{id} {
      allow read, write: if request.auth != null;
    }
    match /operationCosts/{id} {
      allow read, write: if request.auth != null;
    }
    match /costTypes/{id} {
      allow read, write: if request.auth != null;
    }
    // Shared app configuration (e.g. weekday pricing) visible to all users.
    match /appConfig/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
